LOCAL_LLM_BASE_URL=http://localhost:1234/v1
COMFYUI_BASE_URL=http://localhost:8188

# Canonical local ports (used by scripts/docs)
LOCAL_PORT_CAPYBARA_UI=2026
LOCAL_PORT_CAPYBARA_GATEWAY=8001
LOCAL_PORT_CAPYBARA_LANGGRAPH=2024
LOCAL_PORT_COMFYUI=8188

# Optional one-command local stack management for ComfyUI
# COMFYUI_WORKDIR=/Users/yourname/Desktop/comfyUI
# COMFYUI_START_CMD=python3 main.py --listen 0.0.0.0 --port 8188

# Optional gateway API key protection for /api/* endpoints
# CAPYBARA_API_KEY=replace-with-a-strong-random-value
# CAPYBARA_API_KEY_HEADER=x-api-key

# SLACK_BOT_TOKEN=your-slack-bot-token
# SLACK_APP_TOKEN=your-slack-app-token
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"

# LangGraph server recursion limit (default: 25, increase for complex agent runs)
LANGGRAPH_DEFAULT_RECURSION_LIMIT=100
